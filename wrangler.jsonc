{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "careersteps-ai",
  "main": "src/index.js",
  "compatibility_date": "2026-02-27",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "vars": {
    "GEMINI_MODEL": "gemini-1.5-flash"
  },
  "routes": [
    {
      "pattern": "careersteps.in/api/*",
      "zone_name": "careersteps.in"
    }
  ]
}
